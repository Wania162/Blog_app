<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Blog SSR</title>

  <style>
    body { font-family: Arial; background:#f4f4f4; margin:0; }
    header { background:#111827; color:white; padding:15px; }
    .container { max-width:800px; margin:20px auto; }

    .card {
      background:white;
      padding:15px;
      margin-bottom:15px;
      border-radius:10px;
      box-shadow:0 2px 8px rgba(0,0,0,0.1);
    }

    .tag {
      display:inline-block;
      background:#fee2e2;
      color:#dc2626;
      padding:2px 8px;
      border-radius:10px;
      font-size:12px;
      margin-right:5px;
    }

    .meta { font-size:12px; color:gray; margin-top:10px; }

    .empty { text-align:center; padding:50px; color:gray; }
  </style>
</head>

<body>

<header>
  <h2>📝 SSR Blog Posts</h2>
</header>

<div class="container">

  <h3>Total Posts: <%= posts ? posts.length : 0 %></h3>

  <% if (!posts || posts.length === 0) { %>
    <div class="empty">No posts found</div>
  <% } else { %>

    <% posts.forEach(post => { %>

      <div class="card">

        <% if (post.tags && post.tags.length) { %>
          <% post.tags.forEach(tag => { %>
            <span class="tag"><%= tag %></span>
          <% }) %>
        <% } %>

        <h2><%= post.title || "No Title" %></h2>

        <p>
          <%= post.content ? post.content.substring(0, 120) : "No content" %>...
        </p>

        <div class="meta">
          ✍️ <%= post.author?.name || "Unknown" %> |
          👁️ <%= post.views || 0 %> views |
          📅 <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString() : "" %>
        </div>

      </div>

    <% }) %>

  <% } %>

</div>

</body>
</html>